# ---- Django ----
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*

# ---- CORS (the game frontend calls this API cross-origin) ----
CORS_ALLOW_ALL=true
# Or lock it down (comma-separated) and set CORS_ALLOW_ALL=false:
# CORS_ALLOWED_ORIGINS=https://coindrop.example.com,https://www.coindrop.example.com

# ---- Balance backend integration (Liberty hustleback) ----
# MOCK_EXTERNAL=true keeps balances in local SQLite so you can run end-to-end
# with no external backend. Set to false to charge/credit REAL wallets.
MOCK_EXTERNAL=true
MOCK_START_BALANCE=1000

EXTERNAL_BASE_URL=https://hustleback.libertydraw.com
EXTERNAL_API_KEY=your-x-api-key-here
EXTERNAL_API_KEY_HEADER=x-api-key
EXTERNAL_CHARGE_PATH=/payment/other-games/charge/token/
EXTERNAL_CREDIT_PATH=/payment/other-games/credit/earning/
# Optional balance-read endpoint (none provided yet). Blank = charge enforces affordability.
EXTERNAL_BALANCE_PATH=
EXTERNAL_BALANCE_FIELD=balance
EXTERNAL_TIMEOUT=10

# Optional: require this token (X-Session-Token header) on play endpoints.
SESSION_SHARED_SECRET=

# ---- Database ----
# Default is SQLite. To use Postgres, set these (psycopg2-binary in requirements):
# POSTGRES_DB=neonslot
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=secret
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
